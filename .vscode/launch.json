{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Train Pipeline",
            "type": "debugpy",
            "request": "launch",
            
            // If train.py is inside the 'src' folder, use this program path:
            "program": "${workspaceFolder}/train.py",
            
            // (Alternatively, if you prefer running it as a module):
            // "module": "src.train",

            // These are your sys.argv arguments. Update the paths to match where your data actually lives.
            "args": [
                "Base data_hackathon.xlsx",
                "R3_Claims_Merged_data.csv"
            ],
            
            // Forces VS Code to run from the root of your project folder so imports work
            "cwd": "${workspaceFolder}",
            
            // Shows your print() statements in the normal VS Code terminal
            "console": "integratedTerminal",
            
            // Set to true to avoid stepping inside LightGBM/Pandas source code, 
            // keeping you focused only on your own files (train.py, features.py)
            "justMyCode": true 
        }
    ]
}